  <defs>
    <linearGradient id="shield-grad" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#C0C8D8"/>
      <stop offset="50%" stop-color="#E8EDF5"/>
      <stop offset="100%" stop-color="#8A96AA"/>
    </linearGradient>
    <linearGradient id="silver-grad" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#D0D8E8"/>
      <stop offset="100%" stop-color="#909AAA"/>
    </linearGradient>
    <linearGradient id="navy-grad" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#123A7A"/>
      <stop offset="100%" stop-color="#08162F"/>
    </linearGradient>
    <linearGradient id="gold-grad" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#FFD86B"/>
      <stop offset="100%" stop-color="#E0A82E"/>
    </linearGradient>
  </defs>
</svg>
