  <path d="M54 68 L70 52 L66 52 L78 40 L74 40 L86 28" stroke="url(#gold-grad)" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
  <polygon points="86,28 80,32 84,36" fill="#F5C542"/>
