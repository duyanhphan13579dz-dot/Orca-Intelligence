  <rect x="32" y="80" width="5" height="14" rx="1" fill="url(#gold-grad)" opacity="0.9"/>
  <rect x="41" y="73" width="5" height="21" rx="1" fill="url(#gold-grad)" opacity="0.9"/>
  <rect x="50" y="85" width="5" height="9" rx="1" fill="#E53935" opacity="0.85"/>
  <rect x="59" y="76" width="5" height="18" rx="1" fill="url(#gold-grad)" opacity="0.9"/>
  <rect x="68" y="70" width="5" height="24" rx="1" fill="url(#gold-grad)" opacity="0.9"/>
