  <line x1="34.5" y1="77" x2="34.5" y2="80" stroke="url(#gold-grad)" stroke-width="1.2"/>
  <line x1="43.5" y1="70" x2="43.5" y2="73" stroke="url(#gold-grad)" stroke-width="1.2"/>
  <line x1="43.5" y1="94" x2="43.5" y2="96" stroke="url(#gold-grad)" stroke-width="1.2"/>
  <line x1="70.5" y1="66" x2="70.5" y2="70" stroke="url(#gold-grad)" stroke-width="1.2"/>
