  <ellipse cx="62" cy="58" rx="26" ry="18" fill="#0B1F45" transform="rotate(-20 62 58)"/>
  <!-- Orca white belly -->
  <ellipse cx="64" cy="62" rx="14" ry="9" fill="white" opacity="0.92" transform="rotate(-20 64 62)"/>
